# ──────────────────────────────────────────────────────────────
# Shewah B2B — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is .gitignored — never commit real keys.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (safe to be public — no secrets here)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon / public key (safe to be public — RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# !! KEEP THIS SECRET — never prefix with NEXT_PUBLIC_ !!
# Supabase service role key — bypasses RLS, server-only usage
# Find it: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Phase 1 additions (fill when setting up notifications) ──

# Resend API key for transactional email
# RESEND_API_KEY=re_...

# AiSensy WhatsApp API credentials
# AISENSY_API_KEY=...
# AISENSY_TEMPLATE_NAMESPACE=...

# Sentry DSN for error tracking (Phase 1)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=...

# ── Phase 2 additions ────────────────────────────────────────

# Razorpay (payment collection — Phase 2)
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
